# Copy this file to fpga/tang9k_spi_lcd.cst and fill the LCD pin locations
# to match your wiring.

IO_LOC "clk" 52;
IO_PORT "clk" IO_TYPE=LVCMOS18 PULL_MODE=UP;

IO_LOC "btn_n[0]" 3;
IO_LOC "btn_n[1]" 4;
IO_PORT "btn_n[0]" IO_TYPE=LVCMOS18 PULL_MODE=UP;
IO_PORT "btn_n[1]" IO_TYPE=LVCMOS18 PULL_MODE=UP;

IO_LOC "led_n[0]" 10;
IO_LOC "led_n[1]" 11;
IO_LOC "led_n[2]" 13;
IO_LOC "led_n[3]" 14;
IO_LOC "led_n[4]" 15;
IO_LOC "led_n[5]" 16;
IO_PORT "led_n[0]" IO_TYPE=LVCMOS18;
IO_PORT "led_n[1]" IO_TYPE=LVCMOS18;
IO_PORT "led_n[2]" IO_TYPE=LVCMOS18;
IO_PORT "led_n[3]" IO_TYPE=LVCMOS18;
IO_PORT "led_n[4]" IO_TYPE=LVCMOS18;
IO_PORT "led_n[5]" IO_TYPE=LVCMOS18;

# TODO: replace these locations with your actual LCD wiring.
