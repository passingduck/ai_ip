#   lcd_sclk  -> LCD SCL/SCK/CLK
#   lcd_mosi  -> LCD SDA/DIN/MOSI
#   lcd_cs_n  -> LCD CS
#   lcd_dc    -> LCD DC/A0/RS
#   lcd_rst_n -> LCD RST/RES
#   lcd_bl    -> LCD BL/LED/backlight enable
